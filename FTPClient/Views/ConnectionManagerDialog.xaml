<Window x:Class="FTPClient.Views.ConnectionManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:FTPClient.Models"
        Title="연결 관리자"
        Width="680" Height="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="Gulimche, Gulim, Malgun Gothic">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left: Profile List -->
        <DockPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock DockPanel.Dock="Top" Text="저장된 연결" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,6,0,0">
                <Button Content="추가" Width="60" Click="AddProfile_Click" Margin="0,0,4,0"/>
                <Button Content="삭제" Width="60" Click="DeleteProfile_Click"/>
            </StackPanel>
            <ListBox x:Name="ProfileList"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     DisplayMemberPath="Name"
                     FontSize="12"/>
        </DockPanel>

        <!-- Right: Profile Detail -->
        <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                Padding="12" CornerRadius="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          IsEnabled="{Binding HasSelection}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Name -->
                    <Label Grid.Row="0" Content="이름" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,3"
                             Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Protocol -->
                    <Label Grid.Row="1" Content="프로토콜" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,3"
                              x:Name="ProtocolCombo"
                              SelectedItem="{Binding SelectedProfile.Protocol}"
                              SelectionChanged="Protocol_Changed">
                        <models:ProtocolType>FTP</models:ProtocolType>
                        <models:ProtocolType>SFTP</models:ProtocolType>
                    </ComboBox>

                    <!-- Host -->
                    <Label Grid.Row="2" Content="호스트" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,3"
                             Text="{Binding SelectedProfile.Host, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Port -->
                    <Label Grid.Row="3" Content="포트" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,3" Width="80" HorizontalAlignment="Left"
                             Text="{Binding SelectedProfile.Port, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Auth Method -->
                    <Label Grid.Row="4" Content="인증 방식" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,3"
                              x:Name="AuthMethodCombo"
                              SelectedItem="{Binding SelectedProfile.AuthMethod}"
                              SelectionChanged="AuthMethod_Changed">
                        <models:AuthMethod>Password</models:AuthMethod>
                        <models:AuthMethod>PrivateKey</models:AuthMethod>
                        <models:AuthMethod>PasswordAndKey</models:AuthMethod>
                    </ComboBox>

                    <!-- Username -->
                    <Label Grid.Row="5" Content="사용자명" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Margin="0,3"
                             Text="{Binding SelectedProfile.Username, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Password -->
                    <Label Grid.Row="6" Content="비밀번호" VerticalAlignment="Center"/>
                    <PasswordBox Grid.Row="6" Grid.Column="1" Margin="0,3"
                                 x:Name="PasswordField"
                                 PasswordChanged="PasswordField_Changed"/>

                    <!-- Private Key Path -->
                    <Label Grid.Row="7" Content="개인키 파일" VerticalAlignment="Center"
                           Visibility="{Binding ShowPrivateKey, Converter={StaticResource BoolToVis}}"/>
                    <DockPanel Grid.Row="7" Grid.Column="1" Margin="0,3"
                               Visibility="{Binding ShowPrivateKey, Converter={StaticResource BoolToVis}}">
                        <Button DockPanel.Dock="Right" Content="찾기" Width="50" Margin="4,0,0,0"
                                Click="BrowseKey_Click"/>
                        <TextBox Text="{Binding SelectedProfile.PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <!-- Key Passphrase -->
                    <Label Grid.Row="8" Content="키 암호" VerticalAlignment="Center"
                           Visibility="{Binding ShowPrivateKey, Converter={StaticResource BoolToVis}}"/>
                    <PasswordBox Grid.Row="8" Grid.Column="1" Margin="0,3"
                                 x:Name="KeyPassphraseField"
                                 PasswordChanged="KeyPassphrase_Changed"
                                 Visibility="{Binding ShowPrivateKey, Converter={StaticResource BoolToVis}}"/>

                    <!-- Initial Remote Path -->
                    <Label Grid.Row="9" Content="리모트 경로" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Margin="0,3"
                             Text="{Binding SelectedProfile.InitialRemotePath, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Initial Local Path -->
                    <Label Grid.Row="10" Content="로컬 경로" VerticalAlignment="Center"/>
                    <DockPanel Grid.Row="10" Grid.Column="1" Margin="0,3">
                        <Button DockPanel.Dock="Right" Content="찾기" Width="50" Margin="4,0,0,0"
                                Click="BrowseLocalPath_Click"/>
                        <TextBox Text="{Binding SelectedProfile.InitialLocalPath, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <!-- Buttons -->
                    <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button Content="저장" Width="70" Margin="0,0,8,0" Click="Save_Click"/>
                        <Button Content="연결" Width="70" Style="{StaticResource PrimaryButton}"
                                Margin="0,0,8,0" Click="Connect_Click" Foreground="White"/>
                        <Button Content="취소" Width="70" Click="Cancel_Click" IsCancel="True"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
