<Window x:Class="FTPClient.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="입력"
        Width="380" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Gulimche, Gulim, Malgun Gothic">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" Margin="0,0,0,8" FontSize="12"/>
        <TextBox x:Name="InputBox" Grid.Row="1" FontSize="12" Padding="4,3"
                 KeyDown="InputBox_KeyDown"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="확인" Width="70" Click="OkButton_Click" IsDefault="True" Margin="0,0,8,0"/>
            <Button Content="취소" Width="70" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
