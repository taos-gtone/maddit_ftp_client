<Window x:Class="FTPClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FTPClient.Views"
        xmlns:models="clr-namespace:FTPClient.Models"
        Title="FTP Client"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        FontFamily="Gulimche, Gulim, Malgun Gothic">

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="파일(_F)">
                <MenuItem Header="연결 관리자..." Command="{Binding OpenConnectionManagerCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="연결 해제" Command="{Binding DisconnectCommand}"/>
                <Separator/>
                <MenuItem Header="종료" Click="Exit_Click" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="북마크(_B)">
                <MenuItem Header="현재 위치 북마크 추가" Command="{Binding AddBookmarkCommand}"
                          InputGestureText="Ctrl+D"/>
                <Separator/>
                <MenuItem x:Name="BookmarkListMenu" Header="북마크 목록"
                          ItemsSource="{Binding Bookmarks}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding Name}"/>
                            <Setter Property="FontFamily" Value="Gulimche, Gulim, Malgun Gothic"/>
                            <EventSetter Event="Click" Handler="Bookmark_Click"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="도움말(_H)">
                <MenuItem Header="FTP Client 정보" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Quick Connect Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ToolbarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="연결 해제" Margin="4,0,0,0"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding DisconnectCommand}"
                        Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                <Button DockPanel.Dock="Right" Content="빠른 연결" Margin="4,0,0,0"
                        Style="{StaticResource PrimaryButton}" Foreground="White"
                        Command="{Binding QuickConnectCommand}" Padding="12,4"/>
                <Button DockPanel.Dock="Right" Content="연결 관리자" Margin="4,0,4,0"
                        Style="{StaticResource ToolbarButton}"
                        Command="{Binding OpenConnectionManagerCommand}"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="프로토콜:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="65" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                              SelectedItem="{Binding QuickProtocol}">
                        <models:ProtocolType>FTP</models:ProtocolType>
                        <models:ProtocolType>SFTP</models:ProtocolType>
                    </ComboBox>

                    <TextBlock Text="호스트:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="160" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                             Text="{Binding QuickHost, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="사용자:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="100" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                             Text="{Binding QuickUsername, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="비밀번호:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <PasswordBox Width="100" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11"
                                 x:Name="QuickPasswordBox"
                                 PasswordChanged="QuickPassword_Changed"/>

                    <TextBlock Text="포트:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox Width="45" VerticalAlignment="Center" FontSize="11"
                             Text="{Binding QuickPort, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Padding="6,3">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" Foreground="White"/>
            </StatusBarItem>
            <Separator Background="#5599CC"/>
            <StatusBarItem>
                <TextBlock Text="{Binding ConnectionInfo}" Foreground="White"/>
            </StatusBarItem>
            <Separator Background="#5599CC"/>
            <StatusBarItem HorizontalAlignment="Right">
                <ToggleButton x:Name="SyncToggle"
                              IsChecked="{Binding SyncBrowsing}"
                              Padding="8,2" FontSize="11" Cursor="Hand"
                              FontFamily="Gulimche, Gulim, Malgun Gothic">
                    <ToggleButton.Style>
                        <Style TargetType="ToggleButton">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" Background="Transparent"
                                                BorderBrush="#5599CC" BorderThickness="1"
                                                CornerRadius="2" Padding="8,2">
                                            <TextBlock x:Name="text" Text="탐색 동기화: OFF"
                                                       Foreground="White" FontSize="11"
                                                       FontFamily="Gulimche, Gulim, Malgun Gothic"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#28A745"/>
                                                <Setter TargetName="text" Property="Text" Value="탐색 동기화: ON"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ToggleButton.Style>
                </ToggleButton>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- Dual Panel Area -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Local Panel -->
                <views:LocalPanelView Grid.Column="0"
                                       DataContext="{Binding LocalPanel}"/>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                              Background="{StaticResource BorderBrush}" Cursor="SizeWE"/>

                <!-- Remote Panel -->
                <views:RemotePanelView Grid.Column="2"
                                        DataContext="{Binding RemotePanel}"/>
            </Grid>

            <!-- Horizontal Splitter -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" Cursor="SizeNS"/>

            <!-- Transfer Queue -->
            <views:TransferQueueView Grid.Row="2"
                                      DataContext="{Binding TransferQueue}"/>
        </Grid>
    </DockPanel>
</Window>
