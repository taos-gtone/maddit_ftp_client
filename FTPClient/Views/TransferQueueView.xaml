<UserControl x:Class="FTPClient.Views.TransferQueueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Style="{StaticResource PanelHeader}">
            <DockPanel>
                <TextBlock Text="전송 큐" FontWeight="SemiBold" FontSize="12" Margin="4,2"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="완료 항목 삭제" Style="{StaticResource ToolbarButton}" FontSize="11"
                            Command="{Binding ClearCompletedCommand}" Margin="0,0,4,0"/>
                    <Button Content="전체 취소" Style="{StaticResource ToolbarButton}" FontSize="11"
                            Command="{Binding CancelAllCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Transfer List -->
        <ListView ItemsSource="{Binding Transfers}" FontSize="11"
                  VirtualizingStackPanel.IsVirtualizing="True">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="방향" Width="40" DisplayMemberBinding="{Binding DirectionText}"/>
                    <GridViewColumn Header="파일명" Width="200" DisplayMemberBinding="{Binding FileName}"/>
                    <GridViewColumn Header="상태" Width="60" DisplayMemberBinding="{Binding StatusText}"/>
                    <GridViewColumn Header="진행률" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}"
                                                 Maximum="100" Height="14"/>
                                    <TextBlock Text="{Binding ProgressText}" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="리모트 경로" Width="250" DisplayMemberBinding="{Binding RemotePath}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</UserControl>
